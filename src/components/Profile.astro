---
import { Picture } from 'astro:assets';
import ProfilePicture from '../assets/profile.jpg';

const profile = {
    name: 'Dierish Rojas.',
    title: 'Web Developer',
    location: 'Managua, Nicaragua',
    description: 'Desarrollador Front-End enfocado en crear interfaces web funcionales, dinámicas y responsivas utilizando tecnologías modernas. Con experiencia trabajando en proyectos reales usando Svelte, Astro y Tailwind CSS, además de una base sólida en React y JavaScript. Interesado en el desarrollo de experiencias web limpias, escalables y enfocadas en la usabilidad.'
};
---

<div class="flex flex-col gap-6 items-center text-center sm:items-start sm:text-left">

    <div class="flex flex-col sm:flex-row gap-4 sm:items-center">

        <Picture
            src={ProfilePicture}
            formats={['webp']}
            width={384}
            height={384}
            alt={'Profile picture ' + profile.name}
            title={profile.name}
            class="w-24 h-24 rounded-xl object-cover border-2 border-primary mx-auto sm:mx-0"
        />

        <div>

            <h1 class="text-2xl font-extrabold mb-1 inline-block relative text-text-primary">
                {profile.name}
            </h1>

            <p class="text-sm mb-2 text-primary">
                {profile.title}
            </p>

            <p class="flex items-center justify-center sm:justify-start text-sm text-gray-400">
                <svg class="-mt-0.5 inline mr-2"fill=none height=14 stroke=currentColor stroke-linecap=round stroke-linejoin=round stroke-width=2 viewBox="0 0 24 24"width=14 xmlns=http://www.w3.org/2000/svg><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx=12 cy=10 r=3></circle></svg>
                {profile.location}
            </p>

        </div>

    </div>

    <p class="text-sm leading-relaxed mt-4 text-gray-400">
        {profile.description}
    </p>

</div>